# Generated by bun run env:examples. Do not edit by hand.
# This is the development env example for the BrowserOS monorepo root.
# Copy it to .env.development; real .env.development files are gitignored.

# --- dev-tools ---

# CDP protocol JSON input for browser protocol codegen.
# CDP_PROTOCOL_JSON=/path/to/chromium/src/out/Default_arm64/gen/third_party/blink/public/devtools_protocol/protocol.json

# BrowserOS binary used by app dev, eval runs, and Claw dev.
BROWSEROS_BINARY=/Applications/BrowserOS.app/Contents/MacOS/BrowserOS

# --- app ---

# Chromium remote debugging port for app development.
BROWSEROS_CDP_PORT=9005

# BrowserOS server port, also used as the Claw browser launch port.
BROWSEROS_SERVER_PORT=9105

# Extension dev server port for app development.
BROWSEROS_EXTENSION_PORT=9305

# Browser bundle PostHog key.
VITE_PUBLIC_POSTHOG_KEY=

# Browser bundle PostHog host.
VITE_PUBLIC_POSTHOG_HOST=

# Browser bundle Sentry DSN.
VITE_PUBLIC_SENTRY_DSN=

# Public BrowserOS API URL exposed to the browser bundle.
VITE_PUBLIC_BROWSEROS_API=https://api.browseros.com

# Alpha feature flag for the browser bundle.
VITE_ALPHA_FEATURES=true

# Optional GraphQL schema path; falls back to schema/schema.graphql.
GRAPHQL_SCHEMA_PATH=

# Sentry auth token for source-map uploads.
SENTRY_AUTH_TOKEN=

# Sentry organization for source-map uploads.
SENTRY_ORG=

# Sentry project for source-map uploads.
SENTRY_PROJECT=

# --- claw ---

# Optional Claw API base URL override; tools/dev injects this in dev:claw flows and real env wins.
# VITE_BROWSEROS_CLAW_API_URL=http://127.0.0.1:9200

# Optional Chromium user data directory override for Claw dev browser launches.
# BROWSEROS_USER_DATA_DIR=/tmp/my-browseros-dev

# Optional Chromium remote debugging port override shared by Claw app and server dev.
# BROWSEROS_CLAW_CDP_PORT=49337

# Optional BrowserClaw state root override.
# BROWSERCLAW_DIR=~/.browserclaw-dev

# --- server ---

# BrowserOS server config URL required by production server builds and eval runs.
BROWSEROS_CONFIG_URL=https://llm.browseros.com/api/browseros-server/config

# Trusted origins for local server development.
BROWSEROS_TRUSTED_ORIGINS=

# Server telemetry key; CLI release builds read the same key.
POSTHOG_API_KEY=

# Server Sentry DSN.
SENTRY_DSN=

# Node environment for server and build scripts.
NODE_ENV=development

# Server log level.
LOG_LEVEL=info

# Optional AI SDK DevTools capture toggle for local server runs.
# BROWSEROS_AI_SDK_DEVTOOLS=true

# Headless browser setting for local server tests.
BROWSEROS_TEST_HEADLESS=false

# --- eval ---

# OpenRouter provider key used by eval config files.
OPENROUTER_API_KEY=

# Fireworks provider key used by eval config files.
FIREWORKS_API_KEY=

# Anthropic provider key used by eval config files.
ANTHROPIC_API_KEY=

# OpenAI provider key used by eval config files.
OPENAI_API_KEY=

# Google Generative AI provider key used by eval config files.
GOOGLE_GENERATIVE_AI_API_KEY=

# Claude Agent SDK token used by performance_grader.
CLAUDE_CODE_OAUTH_TOKEN=

# Suite-mode eval variant.
EVAL_VARIANT=local

# Suite-mode agent provider.
EVAL_AGENT_PROVIDER=openai-compatible

# Suite-mode agent model.
EVAL_AGENT_MODEL=

# Suite-mode agent API key.
EVAL_AGENT_API_KEY=

# Suite-mode agent base URL.
EVAL_AGENT_BASE_URL=

# Suite-mode agent image support flag.
EVAL_AGENT_SUPPORTS_IMAGES=true

# Optional suite-mode executor model override for orchestrator suites.
EVAL_EXECUTOR_MODEL=

# Optional suite-mode executor API key override.
EVAL_EXECUTOR_API_KEY=

# Optional suite-mode executor base URL override.
EVAL_EXECUTOR_BASE_URL=

# Clado visual action executor model.
CLADO_ACTION_MODEL=

# Clado visual action executor API key.
CLADO_ACTION_API_KEY=

# Clado visual action executor base URL.
CLADO_ACTION_BASE_URL=

# Backward-compatible Clado action URL alias used by older local scripts.
CLADO_ACTION_URL=

# BrowserOS server URL used by the eval runner.
BROWSEROS_SERVER_URL=http://127.0.0.1:9110

# BrowserOS server log directory used by the eval runner.
BROWSEROS_SERVER_LOG_DIR=/tmp/browseros-server-logs

# Captcha solver extension API key.
NOPECHA_API_KEY=

# WebArena-Infinity checkout directory.
WEBARENA_INFINITY_DIR=

# WebArena-Infinity app URL.
INFINITY_APP_URL=

# Eval R2 account ID for publishing and weekly reports.
EVAL_R2_ACCOUNT_ID=

# Eval R2 access key ID for publishing and weekly reports.
EVAL_R2_ACCESS_KEY_ID=

# Eval R2 secret access key for publishing and weekly reports.
EVAL_R2_SECRET_ACCESS_KEY=

# Eval R2 bucket for publishing and weekly reports.
EVAL_R2_BUCKET=browseros-eval

# Eval R2 CDN base URL for published reports.
EVAL_R2_CDN_BASE_URL=https://eval.browseros.com
